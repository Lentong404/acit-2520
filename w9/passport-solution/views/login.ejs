<div class="row mt-5">
  <div class="col-md-6 m-auto">
    <div class="card card-body text-center">
      <h1 class="mb-3">
        <img src="/secure-icon.png" alt="icon" width="20%" />
      </h1>
      <h2>Login</h2>

      <!-- Error messages populated by Passport's failureMessage option -->
      <% if (messages && messages.length > 0) { %>
        <% messages.forEach(function(message) { %>
          <div class="alert alert-danger" role="alert">
            <%= message %>
          </div>
        <% }) %>
      <% } %>

      <form action="/auth/login" method="POST">
        <div class="form-group">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-control"
            placeholder="ex - jimmy123@gmail.com"
          />
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            class="form-control"
            placeholder="ex - jimmy123!"
          />
        </div>
        <button type="submit" class="btn btn-primary btn-block">Login</button>
        <br />
      </form>

      <hr />

      <!-- GitHub OAuth Login -->
      <a href="/auth/github" class="btn btn-dark btn-block">
        <i class="fab fa-github"></i> Login with GitHub
      </a>
    </div>
  </div>
</div>
